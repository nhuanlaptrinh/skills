#!/bin/bash
# Script tự động tạo tên miền con Cloudflare
# Sử dụng: tao_ten_mien <subdomain> [ip]

SCRIPT_DIR="/root/.agents/skills/cloudflare-subdomain"
VENV_DIR="$SCRIPT_DIR/venv"

# Kích hoạt virtual environment và chạy script
cd "$SCRIPT_DIR"
if [ -f "$VENV_DIR/bin/activate" ]; then
    source "$VENV_DIR/bin/activate"
    python3 "$SCRIPT_DIR/cloudflare_dns.py" "$@"
else
    echo "Đang cài đặt dependencies..."
    python3 -m venv venv
    source venv/bin/activate
    pip install -q -r requirements.txt
    python3 "$SCRIPT_DIR/cloudflare_dns.py" "$@"
fi

